{
	"info": {
		"_postman_id": "carteira-financeira-api",
		"name": "Carteira Financeira API",
		"description": "API para sistema de carteira financeira com operações de depósito, saque, transferência e reversão de transações.\n\nBase URL: http://localhost:8000\nTodos os endpoints protegidos exigem o header: Authorization: Bearer {{token}}",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Autenticação",
			"item": [
				{
					"name": "Registrar Usuário",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"João Silva\",\n    \"email\": \"joao@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"description": "Cria um novo usuário e uma carteira BRL automaticamente. Retorna o token de acesso."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.success && response.data.token) {",
									"        pm.environment.set('token', response.data.token);",
									"        pm.environment.set('user_id', response.data.user.id);",
									"        console.log('Token salvo:', response.data.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"joao@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Autentica o usuário e retorna o token Bearer. O token é salvo automaticamente na variável {{token}}."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "logout"]
						},
						"description": "Invalida o token do usuário autenticado."
					},
					"response": []
				},
				{
					"name": "Meu Perfil",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "me"]
						},
						"description": "Retorna os dados do usuário autenticado e sua carteira."
					},
					"response": []
				}
			],
			"description": "Endpoints de autenticação. Faça login primeiro para obter o token."
		},
		{
			"name": "Carteira",
			"item": [
				{
					"name": "Consultar Saldo",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/v1/wallet/balance",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "wallet", "balance"]
						},
						"description": "Retorna o saldo atual da carteira do usuário autenticado."
					},
					"response": []
				},
				{
					"name": "Depósito",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 100.50,\n    \"description\": \"Depósito inicial\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/wallet/deposit",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "wallet", "deposit"]
						},
						"description": "Deposita um valor na carteira. O campo description é opcional."
					},
					"response": []
				},
				{
					"name": "Saque",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 50.00,\n    \"description\": \"Saque para pagamento\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/wallet/withdraw",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "wallet", "withdraw"]
						},
						"description": "Saca um valor da carteira. Retorna erro 422 se saldo insuficiente."
					},
					"response": []
				},
				{
					"name": "Histórico de Transações",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/v1/wallet/history?page=1&per_page=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "wallet", "history"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "per_page", "value": "10" }
							]
						},
						"description": "Retorna o histórico paginado de transações da carteira."
					},
					"response": []
				}
			],
			"description": "Operações da carteira: saldo, depósito, saque e histórico."
		},
		{
			"name": "Transferências",
			"item": [
				{
					"name": "Transferência",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"recipient_id\": 2,\n    \"amount\": 25.75,\n    \"description\": \"Transferência para amigo\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/transactions/transfer",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transactions", "transfer"]
						},
						"description": "Transfere um valor para outro usuário. Use o ID do usuário destinatário no campo recipient_id. Não é possível transferir para si mesmo."
					},
					"response": []
				}
			],
			"description": "Endpoint de transferência entre usuários."
		},
		{
			"name": "Reversões",
			"item": [
				{
					"name": "Solicitar Reversão",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    if (response.success && response.data && response.data.id) {",
									"        pm.environment.set('reversal_id', response.data.id);",
									"        console.log('Reversal ID salvo:', response.data.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"transaction_id\": \"UUID-DA-TRANSACAO-AQUI\",\n    \"reason\": \"user_request\",\n    \"description\": \"Solicitação de estorno pelo usuário\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/transactions/reversal/request",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transactions", "reversal", "request"]
						},
						"description": "Solicita a reversão de uma transação.\n\nCampos:\n- transaction_id: UUID da transação (obrigatório)\n- reason: motivo da reversão (obrigatório) — valores aceitos: user_request, system_error, fraud_detection, compliance\n- description: descrição adicional (opcional)"
					},
					"response": []
				},
				{
					"name": "Aprovar Reversão",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"description\": \"Reversão aprovada após análise\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/transactions/reversal/{{reversal_id}}/approve",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transactions", "reversal", "{{reversal_id}}", "approve"]
						},
						"description": "Aprova uma reversão pendente. Substitua {{reversal_id}} pelo ID numérico da reversão."
					},
					"response": []
				},
				{
					"name": "Rejeitar Reversão",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"description\": \"Reversão rejeitada - transação válida\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/transactions/reversal/{{reversal_id}}/reject",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transactions", "reversal", "{{reversal_id}}", "reject"]
						},
						"description": "Rejeita uma reversão pendente. Substitua {{reversal_id}} pelo ID numérico da reversão."
					},
					"response": []
				}
			],
			"description": "Endpoints de reversão/estorno de transações.\n\nFluxo: solicitar reversão → aguardar aprovação (manual ou automática via job) → aprovada ou rejeitada."
		},
		{
			"name": "Comprovantes",
			"item": [
				{
					"name": "Download Comprovante PDF",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Accept", "value": "application/pdf" }
						],
						"url": {
							"raw": "{{base_url}}/api/v1/transactions/{{transaction_uuid}}/receipt",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transactions", "{{transaction_uuid}}", "receipt"]
						},
						"description": "Faz o download do comprovante em PDF de uma transação. Substitua {{transaction_uuid}} pelo UUID da transação obtido no histórico.\n\nO arquivo PDF será retornado diretamente. No Postman, clique em 'Save to a file' para salvar o PDF."
					},
					"response": []
				}
			],
			"description": "Download de comprovantes em PDF."
		},
		{
			"name": "Sistema",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/health",
							"host": ["{{base_url}}"],
							"path": ["api", "health"]
						},
						"description": "Verifica se a API está no ar. Não requer autenticação."
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": { "type": "text/javascript", "exec": [""] }
		},
		{
			"listen": "test",
			"script": { "type": "text/javascript", "exec": [""] }
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000", "type": "string" }
	]
}
